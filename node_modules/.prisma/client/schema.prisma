// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(cuid())
  name            String
  email           String      @unique
  passwordHash    String?
  percentile      Float?
  category        String?
  preferredBranch String?
  createdAt       DateTime    @default(now())
  shortlists      Shortlist[]
}

model College {
  id           Int         @id @default(autoincrement())
  name         String
  city         String
  district     String?
  type         String
  university   String
  website      String?
  feesMin      Int
  feesMax      Int
  avgPlacement Float?
  hostel       Boolean     @default(false)
  cutoffs      Cutoff[]
  shortlists   Shortlist[]
}

model Cutoff {
  id          Int     @id @default(autoincrement())
  collegeId   Int
  branch      String
  category    String
  year        Int
  round       Int
  percentile  Float
  closingRank Int
  college     College @relation(fields: [collegeId], references: [id])
}

model Shortlist {
  id                 String   @id @default(cuid())
  userId             String
  collegeId          Int
  branch             String
  scenarioPercentile Float
  tag                String
  createdAt          DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  college College @relation(fields: [collegeId], references: [id])
}
